# ─────────────────────────────────────────────────────────────────────────────
# Career Intelligence Platform — Environment Variables
# Copy this to .env.local and fill in values. NEVER commit .env.local.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────────────────────
# For local Docker Compose, keep as-is. For AWS RDS, replace host.
DATABASE_URL=postgresql+asyncpg://jobs:devpassword@postgres:5432/jobsdb
# Plain psycopg2 URL for Alembic (sync migrations)
DATABASE_SYNC_URL=postgresql://jobs:devpassword@localhost:5432/jobsdb
POSTGRES_PASSWORD=devpassword

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
# RedBeat scheduler (Celery Beat)
REDBEAT_REDIS_URL=redis://redis:6379/1

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_64_char_hex_secret
# JWT settings
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match redirect URI registered in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:8000/v1/auth/google/callback

# ── AWS (Phase 2 — S3 for resume uploads) ────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=jobsplatform-resumes-dev

# ── OpenAI (Phase 2 — embeddings + resume parser) ────────────────────────────
OPENAI_API_KEY=

# ── Anti-Detection (Phase 2) ──────────────────────────────────────────────────
# 2captcha API key for CAPTCHA solving
CAPTCHA_API_KEY=
# Brightdata or equivalent residential proxy credentials
PROXY_USERNAME=
PROXY_PASSWORD=
PROXY_HOST=

# ── Error Tracking (Phase 2) ─────────────────────────────────────────────────
SENTRY_DSN=

# ── Next.js Public Variables ──────────────────────────────────────────────────
# These are exposed to the browser — no secrets here
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=debug
